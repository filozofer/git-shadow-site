---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Think in code. Publish clean code." description="Git Shadow separates your local thinking layer from your collaboration layer — automatically.">

  <!-- ─── Hero ─── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badges">
        <div class="hero-badge">Shadow Branch Pattern</div>
        <div class="hero-badge hero-badge-version">v1.0 — stable</div>
      </div>
      <h1 class="hero-title">
        Think in code.<br />Publish clean code.
      </h1>
      <p class="hero-subtitle">
        Git Shadow separates your local thinking layer from your collaboration layer — automatically.
        Write the comments and notes you need. Publish only what your team needs to read.
      </p>
      <div class="hero-actions">
        <a href="/docs/getting-started" class="btn btn-primary">Get started</a>
        <a href="/docs/concept/shadow-branch-pattern" class="btn btn-secondary">Learn the pattern</a>
      </div>
      <div class="hero-branches">
        <code class="branch branch-local">feature/login@local</code>
        <span class="branch-arrow">→</span>
        <code class="branch branch-public">feature/login</code>
        <span class="branch-desc">your thinking layer</span>
        <span class="branch-arrow-spacer"></span>
        <span class="branch-desc">your collaboration layer</span>
      </div>
    </div>
  </section>

  <!-- ─── Demo ─── -->
  <section class="section demo-section">
    <div class="section-inner">
      <div class="demo-wrapper">
        <video class="demo-video" autoplay loop muted playsinline>
          <source src="/demo/demo.mp4" type="video/mp4" />
          <img src="/demo/demo.gif" alt="git shadow workflow demo" />
        </video>
      </div>
    </div>
  </section>

  <!-- ─── Problem ─── -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-title">Every developer has two kinds of code</h2>
      <div class="split">
        <div class="split-card">
          <div class="split-label thinking">Code for thinking</div>
          <p>Exploratory comments. Algorithm sketches. Architecture notes. Debug helpers. AI memory files.</p>
          <p>These structures help you reason during development — but they're often considered noise in a shared repository.</p>
        </div>
        <div class="split-divider">vs</div>
        <div class="split-card">
          <div class="split-label collab">Code for collaboration</div>
          <p>Clean commits. Reviewable diffs. Maintainable history.</p>
          <p>The code your team shares, reviews, and maintains over time.</p>
        </div>
      </div>
      <p class="section-callout">
        Until now, you had to choose between them.<br />
        <strong>Git Shadow removes that compromise.</strong>
      </p>
    </div>
  </section>

  <!-- ─── Concept ─── -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="concept-eyebrow">The Shadow Branch Pattern</div>
      <h2 class="section-title">One feature. Two branches.</h2>
      <p class="section-lead">
        For each feature, Git Shadow maintains two parallel branches — one for your thinking, one for your team.
      </p>
      <div class="branch-diagram">
        <div class="branch-row">
          <code class="branch branch-local">feature/login@local</code>
          <span class="branch-tag">local thinking layer</span>
        </div>
        <div class="branch-row">
          <code class="branch branch-public">feature/login</code>
          <span class="branch-tag">collaboration layer → push to remote</span>
        </div>
      </div>
      <p>
        Your <code>@local</code> branch can contain design comments, pseudo-code, architecture notes, debugging helpers, AI memory files — anything that helps you think.
        The published branch remains <strong>clean and reviewable</strong>.
      </p>
      <a href="/docs/concept/shadow-branch-pattern" class="link-more">Read the full pattern documentation →</a>
    </div>
  </section>

  <!-- ─── Workflow ─── -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-title">Full workflow. Four commands.</h2>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-body">
            <div class="step-cmd"><code>git shadow feature start feature/login</code></div>
            <p>Creates both <code>feature/login</code> and <code>feature/login@local</code>. Switches you to the local branch.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-body">
            <div class="step-cmd">Work on <code>@local</code></div>
            <p>Write your code. Add <code>///</code> comments freely — algorithm steps, decision notes, AI context. No restrictions.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-body">
            <div class="step-cmd"><code>git shadow feature publish --commit -m "feat(auth): login"</code></div>
            <p>Strips local comments. Creates clean commits. Cherry-picks to the public branch. Push normally with <code>git push</code>.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <div class="step-body">
            <div class="step-cmd"><code>git shadow feature finish</code></div>
            <p>After the PR is merged — syncs your shadow base branch, merges your local feature history into it, and cleans up the feature branches.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Code example ─── -->
  <section class="section section-alt">
    <div class="section-inner">
      <h2 class="section-title">Write the code you need to think</h2>
      <p class="section-lead">Your <code>@local</code> branch. Free to annotate.</p>
      <div class="code-compare">
        <div class="code-block">
          <div class="code-label local-label">feature/login@local</div>
          <pre><code>  <span class="comment">/// Get user from database</span>
  const user = await prisma.user.findUnique(&#123;
    where: &#123; email &#125;,
  &#125;)
  if (!user) throw new Error('Invalid credentials')

  <span class="comment">/// Verify account status</span>
  if (!user.isActive) throw new Error('Account disabled')

  <span class="comment">/// Verify password hash</span>
  const valid = await bcrypt.compare(password, user.passwordHash)
  if (!valid) throw new Error('Invalid credentials')

  <span class="comment">/// Build and return session</span>
  return prisma.session.create(&#123; data: &#123; userId: user.id &#125; &#125;)</code></pre>
        </div>
        <div class="code-arrow">→</div>
        <div class="code-block">
          <div class="code-label public-label">feature/login — published</div>
          <pre><code>  const user = await prisma.user.findUnique(&#123;
    where: &#123; email &#125;,
  &#125;)
  if (!user) throw new Error('Invalid credentials')

  if (!user.isActive) throw new Error('Account disabled')

  const valid = await bcrypt.compare(password, user.passwordHash)
  if (!valid) throw new Error('Invalid credentials')

  return prisma.session.create(&#123; data: &#123; userId: user.id &#125; &#125;)</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Benefits ─── -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-title">What you get</h2>
      <div class="benefits">
        <div class="benefit">
          <div class="benefit-icon">⬡</div>
          <h3>Free to think</h3>
          <p>Write every comment, note, and helper you need. No self-censorship. No cleanup tax.</p>
        </div>
        <div class="benefit">
          <div class="benefit-icon">⬡</div>
          <h3>Clean by default</h3>
          <p>Published branches are always clean. One command handles the stripping and cherry-picking.</p>
        </div>
        <div class="benefit">
          <div class="benefit-icon">⬡</div>
          <h3>Just Git</h3>
          <p>No external services. No proprietary formats. Pure shell scripts on top of Git.</p>
        </div>
        <div class="benefit">
          <div class="benefit-icon">⬡</div>
          <h3>AI memory layer</h3>
          <p>The <code>@local</code> branch becomes a versioned, inspectable cognitive workspace for you and your AI tools.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── AI angle ─── -->
  <section class="section section-alt">
    <div class="section-inner section-inner-narrow">
      <div class="concept-eyebrow">AI-assisted development</div>
      <h2 class="section-title">A transparent memory layer for AI</h2>
      <p class="section-lead">
        AI tools have no persistent, transparent memory of your project. You reintroduce context every session.
        The AI builds assumptions you can't see or correct.
      </p>
      <p>
        The <code>@local</code> shadow branch solves this. AI reasoning lives next to the code — visible, versioned, editable.
        Not hidden in prompts. Not locked inside proprietary agents.
      </p>
      <blockquote class="ai-quote">
        Git Shadow allows developers to observe, shape, and version the evolving memory of AI working on their codebase.
      </blockquote>
      <a href="/docs/concept/ai-memory-layer" class="link-more">Explore the AI memory layer concept →</a>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="section cta-section">
    <div class="section-inner section-inner-narrow cta-inner">
      <h2 class="cta-title">Ready to separate thinking from publishing?</h2>
      <div class="hero-actions">
        <a href="/docs/getting-started" class="btn btn-primary">Get started</a>
        <a href="https://github.com/filozofer/git-shadow" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">View on GitHub</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero ─── */
  .hero {
    padding: 6rem 2rem 5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-badges {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
  }

  .hero-badge-version {
    color: #4ade80;
    border-color: color-mix(in srgb, #22c55e 40%, transparent);
    background: color-mix(in srgb, #22c55e 8%, transparent);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .hero-branches {
    display: grid;
    grid-template-columns: auto auto auto;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 0.5rem 0.75rem;
    justify-content: center;
    font-size: 0.8rem;
    color: var(--color-muted);
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    max-width: 420px;
    margin: 0 auto;
  }

  .branch-arrow { color: var(--color-muted); }
  .branch-arrow-spacer { display: block; }

  /* ─── Buttons ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.375rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s, background 0.15s;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #0a0a0b;
  }

  .btn-primary:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: color-mix(in srgb, var(--color-surface) 60%, var(--color-border));
    text-decoration: none;
  }

  /* ─── Branch pills ─── */
  .branch {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    border-radius: 5px;
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .branch-local {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .branch-public {
    background: color-mix(in srgb, #22c55e 10%, transparent);
    color: #4ade80;
    border: 1px solid color-mix(in srgb, #22c55e 25%, transparent);
  }

  .branch-desc {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  /* ─── Sections ─── */
  .section {
    padding: 5rem 2rem;
  }

  .section-alt {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-inner-narrow {
    max-width: 680px;
  }

  .section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
    color: var(--color-text);
  }

  .section-lead {
    font-size: 1.05rem;
    color: var(--color-muted);
    margin: 0 0 1.5rem;
    line-height: 1.7;
  }

  .section-callout {
    text-align: center;
    font-size: 1.05rem;
    color: var(--color-muted);
    margin-top: 2.5rem;
    line-height: 1.7;
  }

  .section-callout strong {
    color: var(--color-text);
  }

  .concept-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .link-more {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-accent);
  }

  /* ─── Demo ─── */
  .demo-section {
    padding-top: 0;
    padding-bottom: 4rem;
  }

  .demo-wrapper {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 32px color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  .demo-video {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ─── Problem split ─── */
  .split {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .split-card {
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .split-card p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .split-card p:last-child {
    margin-bottom: 0;
  }

  .split-divider {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .split-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .split-label.thinking { color: var(--color-accent); }
  .split-label.collab   { color: #4ade80; }

  /* ─── Branch diagram ─── */
  .branch-diagram {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin: 1.5rem 0;
  }

  .branch-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .branch-tag {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  /* ─── Steps ─── */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 1.5rem;
  }

  .step {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .step:last-child {
    border-bottom: none;
  }

  .step-number {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15rem;
  }

  .step-body p {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .step-cmd {
    font-weight: 500;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  /* ─── Code compare ─── */
  .code-compare {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .code-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.75rem;
    border-radius: 5px 5px 0 0;
    margin-bottom: -1px;
  }

  .local-label  { background: color-mix(in srgb, var(--color-accent) 12%, transparent); color: var(--color-accent); }
  .public-label { background: color-mix(in srgb, #22c55e 10%, transparent); color: #4ade80; }

  .code-block pre {
    margin: 0;
    border-radius: 0 8px 8px 8px;
  }

  .code-arrow {
    font-size: 1.25rem;
    color: var(--color-muted);
    margin-top: 2.5rem;
    align-self: start;
  }

  .comment { color: color-mix(in srgb, var(--color-accent) 70%, var(--color-muted)); }

  /* ─── Benefits ─── */
  .benefits {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .benefit {
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .benefit-icon {
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .benefit h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .benefit p {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* ─── AI quote ─── */
  .ai-quote {
    margin: 1.5rem 0 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    border-radius: 0 8px 8px 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
    font-style: italic;
  }

  /* ─── CTA ─── */
  .cta-section {
    text-align: center;
  }

  .cta-inner {
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 2rem;
    color: var(--color-text);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .hero { padding: 3.5rem 1.25rem 3rem; }
    .section { padding: 3rem 1.25rem; }

    .split {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .split-divider { text-align: center; }

    .code-compare {
      grid-template-columns: 1fr;
    }
    .code-arrow { display: none; }
  }
</style>
