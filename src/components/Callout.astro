---
interface Props {
  type?: 'note' | 'tip' | 'warning' | 'danger';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const config = {
  note:    { label: 'Note',    icon: 'ℹ' },
  tip:     { label: 'Tip',     icon: '✦' },
  warning: { label: 'Warning', icon: '⚠' },
  danger:  { label: 'Danger',  icon: '✕' },
};

const { label, icon } = config[type];
---

<div class:list={['callout', `callout-${type}`]}>
  <span class="callout-icon" aria-hidden="true">{icon}</span>
  <div class="callout-body">
    <span class="callout-label">{title ?? label}</span>
    <slot />
  </div>
</div>

<style>
  .callout {
    display: flex;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    border: 1px solid;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .callout-note    { border-color: #3b82f6; background: color-mix(in srgb, #3b82f6 8%, transparent); }
  .callout-tip     { border-color: #22c55e; background: color-mix(in srgb, #22c55e 8%, transparent); }
  .callout-warning { border-color: #f59e0b; background: color-mix(in srgb, #f59e0b 8%, transparent); }
  .callout-danger  { border-color: #ef4444; background: color-mix(in srgb, #ef4444 8%, transparent); }

  .callout-icon {
    flex-shrink: 0;
    font-size: 1rem;
    margin-top: 0.05rem;
  }

  .callout-note    .callout-icon { color: #3b82f6; }
  .callout-tip     .callout-icon { color: #22c55e; }
  .callout-warning .callout-icon { color: #f59e0b; }
  .callout-danger  .callout-icon { color: #ef4444; }

  .callout-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .callout-label {
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .callout-note    .callout-label { color: #3b82f6; }
  .callout-tip     .callout-label { color: #22c55e; }
  .callout-warning .callout-label { color: #f59e0b; }
  .callout-danger  .callout-label { color: #ef4444; }
</style>
